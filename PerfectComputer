function togglePwd() {
  const inp = document.getElementById('loginPwd');
  inp.type = document.getElementById('showPwd').checked ? 'text' : 'password';
}

async function loginStudent() {
  const loginId = document.getElementById('loginId').value.trim();
  const pwd     = document.getElementById('loginPwd').value.trim();
  const errEl   = document.getElementById('loginError');
  errEl.style.display = 'none';

  if (!loginId || !pwd) {
    errEl.textContent = '⚠️ Registration No. और Password दर्ज करें।';
    errEl.style.display = 'block'; return;
  }

  const btn = document.querySelector('#loginStep1 .btn-primary');
  try {
    btn.innerHTML = '<span class="spinner"></span>Logging in...';
    btn.disabled = true;

    if (!db) {
      throw new Error('Database अभी load हो रही है। थोड़ा रुककर फिर try करें।');
    }

    // Try by regNo first
    let snap = await db.collection('students').doc(loginId).get();

    // If not found by regNo, try by mobile
    if (!snap.exists) {
      const q = await db.collection('students').where('mobile', '==', loginId).limit(1).get();
      if (!q.empty) snap = q.docs[0];
    }

    if (!snap || !snap.exists) {
      throw new Error('Registration No. या Mobile नहीं मिला।');
    }

    const data = snap.data ? snap.data() : snap;
    if (data.password !== pwd) {
      throw new Error('Password गलत है।');
    }

    // Success — show dashboard
    closeModal('loginModal');
    showDashboard(data);

  } catch(err) {
    errEl.textContent = '❌ ' + err.message;
    errEl.style.display = 'block';
    btn.innerHTML = '🚀 Login करें';
    btn.disabled = false;
  }
}

function showDashboard(data) {
  const name = data.firstName + ' ' + data.surname;
  document.getElementById('dashName').textContent = name;
  document.getElementById('dashRegNo').textContent = data.regNo;

  const courses = data.courses || [];
  const listEl = document.getElementById('dashCoursesList');

  if (courses.length === 0) {
    listEl.innerHTML = '<div style="text-align:center;color:var(--wood-light);padding:20px">कोई course enrolled नहीं है।<br><small>Center पर आकर enroll करें।</small></div>';
  } else {
    listEl.innerHTML = courses.map(k => {
      const c = COURSES[k];
      if (!c) return '';
      return `<div class="dash-course-card">
        <div class="dash-course-icon">${c.icon}</div>
        <div>
          <div class="dash-course-name">${c.name}</div>
          <div class="dash-course-status">✅ Enrolled | ₹${c.price.toLocaleString()}</div>
        </div>
      </div>`;
    }).join('');
  }

  openModal('dashboardModal');
}

function logoutStudent() {
  closeModal('dashboardModal');
  document.getElementById('loginId').value = '';
  document.getElementById('loginPwd').value = '';
  document.getElementById('loginError').style.display = 'none';
}

