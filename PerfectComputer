function generateRegNo() {
  const year = new Date().getFullYear().toString().slice(-2);
  const rand = Math.floor(1000 + Math.random() * 9000);
  return 'PC' + year + rand;
}

function generatePassword() {
  const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
  let pwd = '';
  for (let i = 0; i < 6; i++) pwd += chars[Math.floor(Math.random() * chars.length)];
  return pwd;
}

async function registerStudent() {
  const firstName  = document.getElementById('regFirstName').value.trim();
  const surname    = document.getElementById('regSurname').value.trim();
  const fatherName = document.getElementById('regFatherName').value.trim();
  const motherName = document.getElementById('regMotherName').value.trim();
  const aadhar     = document.getElementById('regAadhar').value.trim();
  const mobile     = document.getElementById('regMobile').value.trim();

  const errEl = document.getElementById('regError');
  errEl.style.display = 'none';

  if (!firstName || !surname || !fatherName || !motherName) {
    errEl.textContent = '⚠️ कृपया सभी जरूरी fields भरें।';
    errEl.style.display = 'block'; return;
  }
  if (!/^\d{10}$/.test(mobile)) {
    errEl.textContent = '⚠️ Mobile No. 10 digits का होना चाहिए।';
    errEl.style.display = 'block'; return;
  }
  if (aadhar && !/^\d{12}$/.test(aadhar.replace(/\s/g,''))) {
    errEl.textContent = '⚠️ Aadhar No. 12 digits का होना चाहिए।';
    errEl.style.display = 'block'; return;
  }

  const selected = ['rscit','tally','excel','rscfa'].filter(k => document.getElementById('chk-'+k)?.checked);

  const regNo  = generateRegNo();
  const pwd    = generatePassword();
  const pwdHash = pwd; // In production use hashing

  const btn = document.querySelector('#regStep1 .btn-primary');
  try {
    btn.innerHTML = '<span class="spinner"></span>Saving...';
    btn.disabled = true;

    if (!db) {
      // Firebase unavailable — still generate credentials and show success
      console.warn('Firebase unavailable, showing local credentials');
    } else {
      await db.collection('students').doc(regNo).set({
        regNo, firstName, surname, fatherName, motherName,
        aadhar: aadhar.replace(/\s/g,''), mobile,
        courses: selected,
        password: pwdHash,
        createdAt: firebase.firestore.FieldValue.serverTimestamp()
      });
    }

    document.getElementById('regNumber').textContent = regNo;
    document.getElementById('regPassword').textContent = pwd;
    document.getElementById('regStep1').style.display = 'none';
    document.getElementById('regStep2').style.display = 'block';

  } catch(err) {
    console.error(err);
    errEl.textContent = '❌ Registration में error: ' + err.message;
    errEl.style.display = 'block';
    btn.innerHTML = '✅ Register Now';
    btn.disabled = false;
  }
}

