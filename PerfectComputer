const FAST2SMS_KEY = '72BFDazUfL153tAXEs6cQSPYZgI8WTOvHxMnoRkKliqmhyrVdJmhWj7IwEOASL10cUgv4pRrZyHFoCk9';

async function sendSmsOtp(mobile, otp) {
  // Fast2SMS Quick SMS (free tier available)
  // Note: Browser CORS ke wajah se direct call nahi hogi production mein.
  // Isliye hum Firestore mein OTP store karenge aur ek Cloud Function ya
  // proxy se SMS bhejenge. Abhi ke liye fallback: OTP screen pe dikhayenge.
  try {
    // Store OTP in Firestore with 5-min expiry
    if (!db) { return true; } // Firebase unavailable — skip storage, still proceed
    await db.collection('otps').doc(mobile).set({
      otp,
      createdAt: firebase.firestore.FieldValue.serverTimestamp(),
      expiresAt: new Date(Date.now() + 5 * 60 * 1000)
    });

    // Attempt Fast2SMS via no-cors (will be blocked in browser, that's OK)
    // For real deployment: use a Firebase Cloud Function to call Fast2SMS
    const msg = `Perfect Computer Gogunda - OTP: ${otp}. Valid 5 min. Do not share. -Perfect Computer`;
    fetch(`https://www.fast2sms.com/dev/bulkV2?authorization=${FAST2SMS_KEY}&route=q&message=${encodeURIComponent(msg)}&language=english&flash=0&numbers=${mobile}`, {
      mode: 'no-cors'
    }).catch(() => {}); // Silently fail if blocked (expected in browser)

    return true;
  } catch(e) {
    console.error('SMS send error:', e);
    return false;
  }
}

async function verifyOtpFromFirestore(mobile, enteredOtp) {
  try {
    if (!db) return false;
    const doc = await db.collection('otps').doc(mobile).get();
    if (!doc.exists) return false;
    const data = doc.data();
    const expiry = data.expiresAt?.toDate ? data.expiresAt.toDate() : new Date(data.expiresAt);
    if (new Date() > expiry) return false; // Expired
    return data.otp === enteredOtp;
  } catch(e) {
    return false;
  }
}

