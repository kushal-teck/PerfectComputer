// ============================================================
// COURSE PRICE CALCULATOR
// ============================================================
function updateCourseSummary() {
  const selected = [];
  ['rscit','tally','excel','rscfa'].forEach(k => {
    const chk = document.getElementById('chk-' + k);
    const opt = document.getElementById('opt-' + k);
    if (chk && chk.checked) {
      selected.push(k);
      if (opt) opt.classList.add('selected');
    } else if (opt) {
      opt.classList.remove('selected');
    }
  });

  const listEl = document.getElementById('selectedCoursesList');
  const bdEl = document.getElementById('priceBreakdown');
  const paySection = document.getElementById('payNowSection');

  if (selected.length === 0) {
    listEl.innerHTML = '<div class="no-course-msg">👆 ऊपर से course चुनें</div>';
    bdEl.style.display = 'none';
    paySection.style.display = 'none';
    const freeNote = document.getElementById('freeTypingNote');
    if (freeNote) freeNote.style.display = 'none';
    return;
  }

  let total = 0;
  let html = '';
  selected.forEach(k => {
    const c = COURSES[k];
    total += c.price;
    html += `<div class="selected-course-row"><span class="selected-course-badge">${c.icon}</span><span style="flex:1;font-weight:600">${c.name}</span><span>₹${c.price.toLocaleString()}</span></div>`;
  });
  listEl.innerHTML = html;

  let discount = 0;
  let discountLabel = '';
  if (selected.length === 2) { discount = Math.round(total * 0.05); discountLabel = '5% OFF (2 courses)'; }
  if (selected.length === 3) { discount = Math.round(total * 0.10); discountLabel = '10% OFF (3 courses)'; }
  if (selected.length === 4) { discount = Math.round(total * 0.10); discountLabel = '10% OFF (सभी 4 courses)'; }
  const final = total - discount;

  document.getElementById('totalBeforeDiscount').textContent = '₹' + total.toLocaleString();
  document.getElementById('finalAmount').textContent = '₹' + final.toLocaleString();

  const discRow = document.getElementById('discountRow');
  if (discount > 0) {
    discRow.style.display = 'flex';
    document.getElementById('discountBadge').textContent = discountLabel;
    document.getElementById('discountAmount').textContent = '-₹' + discount.toLocaleString();
  } else {
    discRow.style.display = 'none';
  }

  bdEl.style.display = 'block';
  paySection.style.display = 'block';

  // FREE Typing note
  const freeNote = document.getElementById('freeTypingNote');
  if (freeNote) freeNote.style.display = 'flex';

  document.getElementById('payAmount').textContent = '₹' + final.toLocaleString();
}

