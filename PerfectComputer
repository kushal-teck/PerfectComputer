async function handleForgot() {
  const mobile = document.getElementById('forgotMobile').value.trim();
  const errEl  = document.getElementById('loginError');
  const btn    = document.querySelector('#forgotStep .btn-primary');
  errEl.style.display = 'none';

  if (!/^\d{10}$/.test(mobile)) {
    errEl.textContent = '⚠️ सही 10-digit mobile number डालें।';
    errEl.style.display = 'block'; return;
  }

  try {
    btn.innerHTML = '<span class="spinner"></span>Check कर रहे हैं...';
    btn.disabled = true;

    if (!db) {
      throw new Error('Database अभी load हो रही है। थोड़ा रुककर फिर try करें।');
    }

    const q = await db.collection('students').where('mobile', '==', mobile).limit(1).get();
    if (q.empty) {
      errEl.textContent = '❌ यह mobile registered नहीं है।';
      errEl.style.display = 'block';
      btn.innerHTML = '📲 OTP भेजें'; btn.disabled = false; return;
    }

    const otp = Math.floor(100000 + Math.random() * 900000).toString();
    window._pendingOtp   = otp;
    window._pendingMobile = mobile;
    window._pendingDoc   = q.docs[0].id;

    btn.innerHTML = '<span class="spinner"></span>SMS भेज रहे हैं...';

    await sendSmsOtp(mobile, otp);

    // Fallback: show OTP on screen if API key not set
    if (FAST2SMS_KEY === 'YOUR_FAST2SMS_API_KEY') {
      document.getElementById('otpDevNote').style.display = 'block';
      document.getElementById('otpDevCode').textContent = otp;
    } else {
      document.getElementById('otpDevNote').style.display = 'none';
    }

    document.getElementById('forgotStep').style.display = 'none';
    document.getElementById('otpStep').style.display = 'block';
    btn.innerHTML = '📲 OTP भेजें'; btn.disabled = false;

  } catch(err) {
    errEl.textContent = '❌ Error: ' + err.message;
    errEl.style.display = 'block';
    btn.innerHTML = '📲 OTP भेजें'; btn.disabled = false;
  }
}

async function resetPassword() {
  const otp    = document.getElementById('otpInput').value.trim();
  const newPwd = document.getElementById('newPwd').value.trim();
  const errEl  = document.getElementById('loginError');
  const btn    = document.querySelector('#otpStep .btn-primary');
  errEl.style.display = 'none';

  if (!otp || otp.length < 6) {
    errEl.textContent = '⚠️ 6-digit OTP डालें।';
    errEl.style.display = 'block'; return;
  }
  if (newPwd.length < 4) {
    errEl.textContent = '⚠️ Password कम से कम 4 characters का होना चाहिए।';
    errEl.style.display = 'block'; return;
  }

  // Verify OTP — check both local and Firestore
  const localMatch = (otp === window._pendingOtp);
  const storeMatch = await verifyOtpFromFirestore(window._pendingMobile, otp);

  if (!localMatch && !storeMatch) {
    errEl.textContent = '❌ OTP गलत है या expire हो गया।';
    errEl.style.display = 'block'; return;
  }

  try {
    btn.innerHTML = '<span class="spinner"></span>Reset हो रहा है...';
    btn.disabled = true;

    if (db) {
      await db.collection('students').doc(window._pendingDoc).update({ password: newPwd });
      await db.collection('otps').doc(window._pendingMobile).delete().catch(()=>{});
    }

    const suc = document.getElementById('loginSuccess');
    suc.textContent = '✅ Password reset हो गया! अब login करें।';
    suc.style.display = 'block';
    document.getElementById('otpStep').style.display = 'none';
    document.getElementById('loginStep1').style.display = 'block';
    document.getElementById('loginId').value = window._pendingMobile;
    btn.innerHTML = '🔄 Password Reset करें'; btn.disabled = false;
  } catch(err) {
    errEl.textContent = '❌ Error: ' + err.message;
    errEl.style.display = 'block';
    btn.innerHTML = '🔄 Password Reset करें'; btn.disabled = false;
  }
}

